def test_malformed_l0_record_skipped():
    """Malformed L0 JSON treated as unavailable per existing policy."""
    # Write invalid JSON to L0 store
    l0_id = "L0-20260703-malformed"
    write_raw_l0_json(l0_id, '{"incomplete": "record"}')  # missing required fields
    
    pack = assemble_context_pack(
        request=ContextPackRequest(explicit_l0_ids=[l0_id])
    )
    
    # Validation fails during load; item skipped
